<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
    <extension
        point="org.eclipse.core.runtime.applications"
        id="com.github.cabutchei.rsp.server.liberty.application">
        <application
            cardinality="singleton-global"
            thread="main"
            visible="true">
                  <run class="com.github.cabutchei.rsp.server.liberty.impl.EntryPoint"/>
        </application>
    </extension>
    <extension
        point="org.eclipse.core.runtime.products"
        id="com.github.cabutchei.rsp.server.liberty.product">
        <product
            name="RSP Liberty"
            application="com.github.cabutchei.rsp.server.liberty.application">
        </product>
    </extension>
</plugin>