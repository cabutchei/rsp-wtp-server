{
  "serverTypes": {
    "com.ibm.ws.ast.st.v85.server.base": {
      "template": "liberty.template",
      "discoveries": {
        "websphere.8.x": {
          "discoveryType": "xml",
          "name": "WebSphere Traditional 8.x",
          "nameFile": "properties/version/platform.websphere",
          "nameKey": "@name",
          "nameRequiredPrefix": "IBM WebSphere",
          "versionFile": "properties/version/platform.websphere",
          "versionKey": "@version",
          "versionRequiredPrefix": "8.5"
        }
      },
      "type": {
        "name": "WebSphere Traditional 8.5.x",
        "description": "A server adapter capable of discovering and controlling a WebSphere Traditional 8.x runtime instance."
      }
    }
  },
  "templates": {
    "liberty.template": {
      "type": {
        "launchModes": "run,debug",
        "attributes": {
          "required": {
            "server.home.dir": {
              "type": "string",
              "description": "A filesystem path pointing to a server installation's root directory",
              "defaultValue": "",
              "secret": "false"
            },
            "server.websphere.profile": {
              "type": "string",
              "description": "The server profile name"
            }
          },
          "staticDefaults": {
            "server.http.port": {
              "type": "int",
              "value": "9080"
            },
            "server.classpath.additions": {
              "type": "string",
              "value": ""
            }
          }
        },
        "behavior": {
          "publish": {
            "deployPath": "usr/servers/${server.liberty.id}/customDropins",
            "approvedSuffixes": "war,ear,jar",
            "supportsExploded": "true"
          },
          "startup": {
            "launchType": "java-launch",
            "launchProperties": {
              "workingDirectory": "bin",
              "mainType": "com.ibm.ws.kernel.boot.cmdline.EnvCheck",
              "programArgs": "${server.liberty.id}",
              "vmArgs": "-javaagent:${server.home.dir}/bin/tools/ws-javaagent.jar -Djava.awt.headless=true -Djdk.attach.allowAttachSelf=true",
              "classpath": "bin/tools/ws-server.jar;lib/com.ibm.ws.kernel.boot_1.0.48.jar;${server.classpath.additions}"
            },
            "poller": "webPoller",
            "pollerProperties": {
              "url": "http://localhost:${server.http.port}"
            },
            "onProcessTerminated": "setServerStateStopped"
          },
          "shutdown": {
            "launchType": "java-launch",
            "launchProperties": {
              "workingDirectory": "bin",
              "mainType": "com.ibm.ws.kernel.boot.cmdline.EnvCheck",
              "programArgs": "${server.liberty.id} --stop",
              "vmArgs": "-javaagent:${server.home.dir}/bin/tools/ws-javaagent.jar -Djava.awt.headless=true -Djdk.attach.allowAttachSelf=true",
              "classpath": "bin/tools/ws-server.jar;lib/com.ibm.ws.kernel.boot_1.0.48.jar;${server.classpath.additions}"
            },
            "poller": "webPoller",
            "pollerProperties": {
              "url": "http://localhost:${server.http.port}"
            }
          },
          "actions": {
            "showInBrowser": {
              "baseUrl": "http://localhost:${server.http.port}",
              "deploymentStrategy": "appendDeploymentNameRemoveSuffix"
            },
            "editServerConfiguration": {
              "paths": "profiles/${server.websphere.profile}/config/server.xml"
            }
          }
        }
      }
    }
  }
}
